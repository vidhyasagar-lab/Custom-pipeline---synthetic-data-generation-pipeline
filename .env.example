# ============================================================================
# SynthGen Studio — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your Azure OpenAI credentials.
#   cp .env.example .env
# ============================================================================

# --------------------------------------------------------------------------
# Generation Model (Azure OpenAI)
# Used for: question generation, answer generation, KG extraction
# --------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://your-generation-endpoint.openai.azure.com/
AZURE_OPENAI_API_KEY=your-generation-api-key
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_GPT54MINI_MODEL_NAME=gpt-4o
AZURE_OPENAI_GPT54MINI_DEPLOYMENT_NAME=gpt-4o

# --------------------------------------------------------------------------
# Validation Model (Azure OpenAI — separate endpoint recommended)
# Used for: quality validation, advanced metrics
# Using a different model avoids self-evaluation bias.
# --------------------------------------------------------------------------
AZURE_OPENAI_VALIDATION_ENDPOINT=https://your-validation-endpoint.openai.azure.com/
AZURE_OPENAI_VALIDATION_API_KEY=your-validation-api-key
AZURE_OPENAI_VALIDATION_API_VERSION=2025-04-01-preview
AZURE_OPENAI_VALIDATION_MODEL_NAME=gpt-4o-mini
AZURE_OPENAI_VALIDATION_DEPLOYMENT_NAME=gpt-4o-mini

# --------------------------------------------------------------------------
# Embedding Model (Azure OpenAI)
# Used for: semantic chunking, deduplication, hybrid retrieval (FAISS)
# --------------------------------------------------------------------------
AZURE_OPENAI_EMBEDDING_ENDPOINT=https://your-embedding-endpoint.openai.azure.com/
AZURE_OPENAI_EMBEDDING_API_KEY=your-embedding-api-key
AZURE_OPENAI_EMBEDDING_API_VERSION=2025-01-01-preview
AZURE_OPENAI_EMBEDDING_MODEL_NAME=text-embedding-ada-002
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-ada-002

# --------------------------------------------------------------------------
# Pipeline Configuration
# --------------------------------------------------------------------------
QUALITY_THRESHOLD=0.7              # Min score to accept a QA triple (0.0-1.0)
MAX_RETRIES=3                      # Borderline retry attempts
CHUNK_SIZE=2000                    # Target chunk size (chars)
CHUNK_OVERLAP=300                  # Overlap between chunks (chars)
BATCH_SIZE=10                      # LLM batch size
MAX_CONCURRENT_CALLS=5             # Parallel LLM calls per batch
MAX_UPLOAD_SIZE_MB=50              # Max document upload size

# --------------------------------------------------------------------------
# Tunable Thresholds
# --------------------------------------------------------------------------
MAX_QUESTIONS_PER_CHUNK=15         # Max questions generated per chunk
SIMILARITY_THRESHOLD=0.75          # Semantic chunking break point (lower = more chunks)
DEDUP_THRESHOLD=0.92               # Question similarity to consider duplicate
DENSE_WEIGHT=0.6                   # RRF weight for FAISS dense retrieval
SPARSE_WEIGHT=0.4                  # RRF weight for BM25 sparse retrieval

# --------------------------------------------------------------------------
# Multi-Hop Configuration
# --------------------------------------------------------------------------
ENABLE_MULTIHOP=true               # Enable multi-hop question generation
MULTIHOP_SIMILARITY_MIN=0.4        # Lower bound of similarity band
MULTIHOP_SIMILARITY_MAX=0.82       # Upper bound of similarity band
MAX_MULTIHOP_PAIRS=50              # Max chunk pairs to process
MULTIHOP_QUESTIONS_PER_PAIR=3      # Questions generated per pair

# --------------------------------------------------------------------------
# Feature Toggles
# --------------------------------------------------------------------------
ENABLE_KNOWLEDGE_GRAPH=true        # Build KG for multi-hop pair selection
ENABLE_ADVANCED_METRICS=true       # RAGAS-inspired metrics on validated triples
ENABLE_PERSONAS=true               # Persona/style/length diversity in questions
ENABLE_COST_TRACKING=true          # Track token usage and estimated costs

# --------------------------------------------------------------------------
# Persona & Query Diversity
# --------------------------------------------------------------------------
ACTIVE_PERSONAS=beginner,expert,impatient,curious_student,non_native_speaker
ACTIVE_QUERY_STYLES=conversational,web_search,formal
ACTIVE_QUERY_LENGTHS=short,medium,long

# --------------------------------------------------------------------------
# Advanced Metrics
# --------------------------------------------------------------------------
NOISE_SENSITIVITY_SAMPLE_RATE=0.1  # Fraction of triples to test noise sensitivity
